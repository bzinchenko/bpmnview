<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net472</TargetFramework>
    <AssemblyName>BPMN.View</AssemblyName>
    <RootNamespace>BPMN.View</RootNamespace>
    <ApplicationIcon>BPMN.ico</ApplicationIcon>
    <ApplicationManifest>Properties\app.manifest</ApplicationManifest>
    <UseWindowsForms>true</UseWindowsForms>
    <OutputPath>..\..\Bin\$(Configuration)\</OutputPath>
    <ProjectGuid>{4229F825-61EC-4D72-8FBF-763D36F3D9B7}</ProjectGuid>
    <AssemblyTitle>BPMN View</AssemblyTitle>
    <AssemblyDescription>A free utility to view business models in a popular BPMN notation. Print BPMN models and save them in a number of graphical formats. Credits to all members of BPMN MIWG for inspiring this application.</AssemblyDescription>
    <Company>BPMN Model Interchange Working Group</Company>
    <Product>BPMN View</Product>
    <Copyright>Copyright © Boris Zinchenko, 2017</Copyright>
    <AssemblyVersion>1.0.2.*</AssemblyVersion>
    <FileVersion>1.0.2.0</FileVersion>
    <Deterministic>false</Deterministic>
    <NeutralLanguage></NeutralLanguage>
    <ComVisible>false</ComVisible>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BPMN.Sharp" Version="1.1.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="AboutBox.Designer.cs">
      <DependentUpon>AboutBox.cs</DependentUpon>
    </Compile>
    <Compile Update="ElementControl.Designer.cs">
      <DependentUpon>ElementControl.cs</DependentUpon>
    </Compile>
    <Compile Update="ElementsForm.Designer.cs">
      <DependentUpon>ElementsForm.cs</DependentUpon>
    </Compile>
    <Compile Update="MainForm.Designer.cs">
      <DependentUpon>MainForm.cs</DependentUpon>
    </Compile>
    <Compile Update="ModelForm.Designer.cs">
      <DependentUpon>ModelForm.cs</DependentUpon>
    </Compile>
    <Compile Update="Properties\Resources.Designer.cs">
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
    <Compile Update="Properties\Settings.Designer.cs">
      <AutoGen>True</AutoGen>
      <DependentUpon>Settings.settings</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="AboutBox.resx">
      <DependentUpon>AboutBox.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="ElementControl.resx">
      <DependentUpon>ElementControl.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="ElementsForm.resx">
      <DependentUpon>ElementsForm.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="MainForm.resx">
      <DependentUpon>MainForm.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="ModelForm.resx">
      <DependentUpon>ModelForm.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="Properties\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <None Update="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>

</Project>
